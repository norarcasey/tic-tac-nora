{
  "name": "@norarcasey/tic-tac-nora",
  "version": "0.1.0",
  "type": "module",
  "description": "An embeddable React Tic Tac Nora game — play one vs computer, with an optimal (minimax) AI.",
  "license": "MIT",
  "author": "Nora Casey",
  "homepage": "https://github.com/norarcasey/tic-tac-nora#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/norarcasey/tic-tac-nora.git"
  },
  "bugs": {
    "url": "https://github.com/norarcasey/tic-tac-nora/issues"
  },
  "keywords": [
    "tic-tac-toe",
    "react",
    "component",
    "game",
    "minimax",
    "ai",
    "typescript"
  ],
  "main": "./dist/tic-tac-nora.js",
  "module": "./dist/tic-tac-nora.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tic-tac-nora.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "tsc -p tsconfig.lib.json && vite build --mode lib",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build:lib"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-dts": "^4.0.3",
    "vitest": "^2.0.5"
  }
}
